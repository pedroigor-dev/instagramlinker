# Opcao recomendada para producao: use um backend/resolvedor dedicado.
# INSTAGRAM_RESOLVER_ENDPOINT=https://seu-backend.example.com/resolve
# INSTAGRAM_RESOLVER_TOKEN=token-opcional

# Uso local apenas. Nunca suba cookies pessoais para GitHub/Vercel.
# YTDLP_COOKIES_PATH=./www.instagram.com_cookies.txt

# Em producao, cookies pessoais ficam bloqueados por padrao.
# Defina isto somente se voce entender que usuarios publicos podem acionar
# downloads usando a sessao dessa conta.
# ALLOW_SERVER_COOKIES=false
